{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enricher Agent Output",
  "description": "Контракт: что возвращает Enricher Agent → принимает CRM Writer Agent",
  "type": "object",
  "required": ["enricher_metadata", "leads"],
  "properties": {
    "organization_data": {
      "type": "object",
      "description": "Company-level data from Apollo organization objects, keyed by company_domain. One entry per unique company encountered during enrichment. Optional — omit if no organization data was returned by Apollo.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "company_name": { "type": "string" },
          "phone": { "type": ["string", "null"] },
          "raw_address": { "type": ["string", "null"] },
          "revenue_printed": { "type": ["string", "null"] },
          "linkedin_url": { "type": ["string", "null"] },
          "estimated_num_employees": { "type": ["integer", "null"] }
        }
      }
    },
    "enricher_metadata": {
      "type": "object",
      "required": ["timestamp", "total_requested", "total_approved", "credits_spent", "credits_remaining", "emails_found", "emails_not_found"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total_requested": { "type": "integer", "description": "Сколько лидов было в Bucket B" },
        "total_approved": { "type": "integer", "description": "Сколько пользователь одобрил" },
        "credits_spent": { "type": "integer" },
        "credits_remaining": { "type": "integer" },
        "credits_saved": { "type": "integer", "description": "Кредиты, сэкономленные через бесплатные пути" },
        "emails_found": { "type": "integer" },
        "emails_not_found": { "type": "integer" },
        "catchall": { "type": "integer" },
        "success_rate": { "type": "number", "description": "emails_found / total_approved" },
        "recommendation": { "type": ["string", "null"], "description": "Рекомендация агента если результат слабый" }
      }
    },
    "leads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["first_name", "last_name", "title", "company", "company_domain", "email", "email_status", "enrichment_flags"],
        "properties": {
          "apollo_person_id": { "type": ["string", "null"] },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "company_domain": { "type": "string" },
          "country": { "type": ["string", "null"] },
          "email": { "type": ["string", "null"] },
          "email_status": { "type": ["string", "null"], "enum": ["verified", "catchall", "unverified", "unavailable", null] },
          "phone": { "type": ["string", "null"] },
          "linkedin_url": { "type": ["string", "null"] },
          "seniority": { "type": ["string", "null"], "description": "Passthrough из Discoverer — нужен CRM Writer для priority sorting" },
          "contacts_found": {
            "type": "object",
            "description": "Контакты, найденные Discoverer Agent — пробрасываются из входа как есть",
            "properties": {
              "linkedin_url": { "type": ["string", "null"] },
              "twitter": { "type": ["string", "null"] },
              "instagram": { "type": ["string", "null"] },
              "telegram_handle": { "type": ["string", "null"] },
              "email_pattern": { "type": ["string", "null"] },
              "phone": { "type": ["string", "null"] },
              "whatsapp": { "type": ["string", "null"] },
              "conference_appearances": { "type": "array", "items": { "type": "string" } },
              "sources": { "type": "array", "items": { "type": "string" } }
            }
          },
          "verification_status": {
            "type": "string",
            "enum": ["VERIFIED", "PARTIALLY_VERIFIED", "NOT_VERIFIED", "ROLE_DISCREPANCY", "LEFT_COMPANY"],
            "description": "Passthrough из Discoverer — нужен Orchestrator для сборки CRM Writer input"
          },
          "headline": { "type": ["string", "null"], "description": "Passthrough из Discoverer — LinkedIn headline лида. Напр. 'Driving Profitable UA in FX & FinTech'" },
          "role_description": { "type": ["string", "null"], "description": "Описание текущей позиции из Apollo employment_history (current=true). Извлекается при enrichment из apollo_people_match. Напр. 'Managing $2M monthly ad spend across Meta, Google, TikTok'. Если Discoverer уже нашёл — passthrough, иначе Enricher заполняет из Apollo." },
          "verification_note": { "type": "string", "description": "Passthrough из Discoverer — персонализационные сигналы" },
          "enrichment_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "EMAIL_VERIFIED, EMAIL_CATCHALL, EMAIL_NOT_FOUND, EMAIL_UNVERIFIED, JOB_CHANGED, LEFT_COMPANY, FREE_PATH_USED, MISSING_APOLLO_ID"
          },
          "enrichment_note": { "type": "string" }
        }
      }
    }
  },
  "examples": [
    {
      "organization_data": {
        "superbet.com": {
          "company_name": "Superbet",
          "phone": "+40213100100",
          "raw_address": "Bucharest, Romania",
          "revenue_printed": "$500M",
          "linkedin_url": "https://linkedin.com/company/superbet",
          "estimated_num_employees": 3500
        },
