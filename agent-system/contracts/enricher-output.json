        "credits_remaining": 18,
        "credits_saved": 2,
        "emails_found": 3,
        "emails_not_found": 1,
        "catchall": 0,
        "success_rate": 0.75,
        "recommendation": null
      },
      "leads": [
        {
          "apollo_person_id": "1234xyz",
          "first_name": "Ana",
          "last_name": "Silva",
          "title": "Growth Marketing Manager",
          "company": "Superbet",
          "company_domain": "superbet.com",
          "country": "Brazil",
          "email": "ana.silva@superbet.com",
          "email_status": "verified",
          "phone": "+55119876543",
          "linkedin_url": "https://linkedin.com/in/ana-silva-superbet",
          "seniority": "Senior",
          "contacts_found": {
            "linkedin_url": "https://linkedin.com/in/ana-silva-superbet",
            "twitter": "@anasilva_mkt",
            "instagram": null,
            "telegram_handle": null,
            "email_pattern": null,
            "phone": null,
            "whatsapp": null,
            "conference_appearances": [],
            "sources": ["LinkedIn", "Twitter"]
          },
          "verification_status": "PARTIALLY_VERIFIED",
          "headline": "Scaling UA across LatAm | Superbet",
          "role_description": "Leading user acquisition strategy for LatAm markets. Managing performance campaigns across Meta, Google, TikTok with $1.5M monthly budget.",
          "verification_note": "LinkedIn найден, роль совпадает, но email не найден бесплатно",
          "enrichment_flags": ["EMAIL_VERIFIED", "FREE_PATH_USED"],
          "enrichment_note": "Email найден через бесплатный re-query по паттерну домена"
        },
        {
          "apollo_person_id": "5678def",
          "first_name": "João",
          "last_name": "Costa",
          "title": "UA Manager",
          "company": "Stake",
          "company_domain": "stake.com",
          "country": "Brazil",
          "email": null,
          "email_status": "unavailable",
          "phone": null,
          "linkedin_url": "https://linkedin.com/in/joao-costa",
          "seniority": "Manager",
          "contacts_found": {
            "linkedin_url": "https://linkedin.com/in/joao-costa",
            "twitter": null,
            "instagram": null,
            "telegram_handle": null,
            "email_pattern": null,
            "phone": null,
            "whatsapp": null,
            "conference_appearances": [],
            "sources": ["LinkedIn"]
          },
          "verification_status": "VERIFIED",
          "headline": "UA Manager | iGaming | Performance Marketing",
          "role_description": null,
          "verification_note": "LinkedIn актуален, роль UA Manager подтверждена",
          "enrichment_flags": ["EMAIL_NOT_FOUND"],
          "enrichment_note": "Apollo вернул null, LinkedIn URL не помог. Домен stake.com — catchall не подтверждён."
        }
      ]
    }
  ]
}
