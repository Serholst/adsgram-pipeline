{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRM Writer Agent Input",
  "description": "Контракт: что Orchestrator передаёт CRM Writer Agent. Объединённый пакет из Bucket A (Discoverer) + enriched Bucket B (Enricher).",
  "type": "object",
  "required": ["write_metadata", "leads"],
  "properties": {
    "write_metadata": {
      "type": "object",
      "required": ["timestamp", "total_leads", "from_bucket_a", "from_bucket_b", "session_query"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total_leads": { "type": "integer" },
        "from_bucket_a": { "type": "integer", "description": "Лиды из Discoverer Bucket A (уже с контактами)" },
        "from_bucket_b": { "type": "integer", "description": "Лиды из Enricher (бывший Bucket B)" },
        "session_query": { "type": "string", "description": "Исходный запрос пользователя" }
      }
    },
    "leads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["first_name", "last_name", "title", "company", "company_domain", "source_bucket", "verification_status", "lead_status"],
        "properties": {
          "apollo_person_id": { "type": ["string", "null"] },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "company_domain": { "type": "string" },
          "country": { "type": ["string", "null"] },
          "seniority": { "type": ["string", "null"] },
          "vertical": { "type": ["string", "null"], "enum": ["iGaming", "VPN", "Crypto", "Adult", null], "description": "Вертикаль компании — определяется Orchestrator из запроса пользователя" },
          "source_bucket": { "type": "string", "enum": ["A", "B"], "description": "Откуда пришёл лид: A = Discoverer, B = Enricher" },
          "verification_status": {
            "type": "string",
            "enum": ["VERIFIED", "PARTIALLY_VERIFIED", "NOT_VERIFIED", "ROLE_DISCREPANCY", "LEFT_COMPANY"]
          },
          "verification_note": { "type": "string" },
          "lead_status": {
            "type": "string",
            "enum": ["Verified", "Partially verified", "Not verified", "Skip"],
            "description": "Статус для записи в CRM — Title Case. Outreach Writer фильтрует по Verified/Partially verified. Skip-лиды записываются для дедупликации."
          },
          "email": { "type": ["string", "null"], "description": "Из Discoverer (Bucket A) или Enricher (Bucket B)" },
          "email_status": { "type": ["string", "null"], "enum": ["verified", "catchall", "unverified", "unavailable", null] },
          "email_source": { "type": "string", "enum": ["qualifier_pattern", "enricher_apollo", "enricher_free_path"], "description": "Откуда получен email" },
          "phone": { "type": ["string", "null"] },
          "linkedin_url": { "type": ["string", "null"] },
          "twitter": { "type": ["string", "null"] },
          "instagram": { "type": ["string", "null"], "description": "Instagram handle → CRM: Socials" },
          "telegram_handle": { "type": ["string", "null"], "description": "Telegram @handle → CRM: Socials" },
          "whatsapp": { "type": ["string", "null"], "description": "WhatsApp number → CRM: Alt Contacts" },
          "conference_appearances": { "type": "array", "items": { "type": "string" } },
          "contact_sources": { "type": "array", "items": { "type": "string" }, "description": "Все источники контактной информации" },
          "enrichment_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Для Bucket B: EMAIL_VERIFIED, EMAIL_CATCHALL и т.д. Для Bucket A: пусто"
          },
          "flags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "examples": [
    {
      "write_metadata": {
        "timestamp": "2026-03-20T16:00:00Z",
        "total_leads": 2,
        "from_bucket_a": 1,
        "from_bucket_b": 1,
        "session_query": "iGaming Brazil"
      },
      "leads": [
        {
          "apollo_person_id": "6789abc",
          "first_name": "Carlos",
          "last_name": "Mendes",
          "title": "Media Buyer",
          "company": "Betano",
          "company_domain": "betano.com",
          "country": "Brazil",
          "seniority": "Manager",
          "vertical": "iGaming",
          "source_bucket": "A",
          "verification_status": "VERIFIED",
          "verification_note": "LinkedIn актуален, роль подтверждена, спикер на SBC Summit Latam 2025",
          "lead_status": "Verified",
          "email": "c.mendes@betano.com",
          "email_status": "unverified",
          "email_source": "qualifier_pattern",
          "phone": null,
          "linkedin_url": "https://linkedin.com/in/carlosmendes",
          "twitter": null,
          "whatsapp": null,
          "conference_appearances": ["SBC Summit Latam 2025"],
          "contact_sources": ["LinkedIn", "ZoomInfo", "SBC Summit agenda"],
          "enrichment_flags": [],
          "flags": []
        },
        {
          "apollo_person_id": "1234xyz",
          "first_name": "Ana",
          "last_name": "Silva",
          "title": "Growth Marketing Manager",
          "company": "Superbet",
          "company_domain": "superbet.com",
          "country": "Brazil",
          "seniority": "Senior",
          "vertical": "iGaming",
          "source_bucket": "B",
          "verification_status": "PARTIALLY_VERIFIED",
          "verification_note": "LinkedIn найден, роль совпадает, но email не найден бесплатно",
          "lead_status": "Partially verified",
          "email": "ana.silva@superbet.com",
          "email_status": "verified",
          "email_source": "enricher_apollo",
          "phone": "+55119876543",
          "linkedin_url": "https://linkedin.com/in/ana-silva-superbet",
          "twitter": "@anasilva_mkt",
          "whatsapp": null,
          "conference_appearances": [],
          "contact_sources": ["LinkedIn", "Twitter", "Apollo Enrich"],
          "enrichment_flags": ["EMAIL_VERIFIED"],
          "flags": []
        }
      ]
    }
  ]
}
