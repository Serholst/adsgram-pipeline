{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRM Writer Agent Input",
  "description": "Контракт: что Orchestrator передаёт CRM Writer Agent. Объединённый пакет из Bucket A (Discoverer) + enriched Bucket B (Enricher) + SKIP-лиды (для дедупликации).",
  "type": "object",
  "required": ["write_metadata", "leads"],
  "properties": {
    "write_metadata": {
      "type": "object",
      "required": ["timestamp", "total_leads", "from_bucket_a", "from_bucket_b", "from_skip", "session_query"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total_leads": { "type": "integer" },
        "from_bucket_a": { "type": "integer", "description": "Лиды из Discoverer Bucket A (уже с контактами)" },
        "from_bucket_b": { "type": "integer", "description": "Лиды из Enricher (бывший Bucket B)" },
        "from_skip": { "type": "integer", "description": "SKIP-лиды из Discoverer (для дедупликации в CRM)" },
        "session_query": { "type": "string", "description": "Исходный запрос пользователя" }
      }
    },
    "leads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["first_name", "last_name", "title", "company", "company_domain", "source_bucket", "verification_status", "lead_status"],
        "properties": {
          "apollo_person_id": { "type": ["string", "null"] },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "company_domain": { "type": "string" },
          "country": { "type": ["string", "null"] },
          "seniority": { "type": ["string", "null"] },
          "vertical": { "type": ["string", "null"], "enum": ["iGaming", "VPN", "Crypto", "Adult", null], "description": "Вертикаль компании — определяется Orchestrator из запроса пользователя" },
          "source_bucket": { "type": "string", "enum": ["A", "B", "SKIP"], "description": "Откуда пришёл лид: A = Discoverer, B = Enricher, SKIP = Discoverer (skip-лид для дедупликации)" },
          "verification_status": {
            "type": "string",
            "enum": ["VERIFIED", "PARTIALLY_VERIFIED", "NOT_VERIFIED", "ROLE_DISCREPANCY", "LEFT_COMPANY", "SKIP"]
          },
          "verification_note": { "type": "string" },
          "lead_status": {
            "type": "string",
            "enum": ["Verified", "Partially verified", "Not verified", "Needs review", "Skip"],
            "description": "Статус для записи в CRM — Title Case. Outreach Writer фильтрует по Verified/Partially verified. Needs review — для edge cases (конфликт дедупликации и т.д.). Skip-лиды записываются для дедупликации."
          },
          "email": { "type": ["string", "null"], "description": "Из Discoverer (Bucket A) или Enricher (Bucket B). Для SKIP — если есть, полезно для dedup" },
          "email_status": { "type": ["string", "null"], "enum": ["verified", "catchall", "unverified", "unavailable", null] },
          "email_source": { "type": ["string", "null"], "enum": ["discoverer_pattern", "enricher_apollo", "enricher_free_path", null], "description": "Откуда получен email. null для SKIP-лидов без email" },
          "phone": { "type": ["string", "null"] },
          "linkedin_url": { "type": ["string", "null"] },
          "twitter": { "type": ["string", "null"] },
          "instagram": { "type": ["string", "null"], "description": "Instagram handle → CRM: Socials" },
          "telegram_handle": { "type": ["string", "null"], "description": "Telegram @handle → CRM: Socials" },
          "whatsapp": { "type": ["string", "null"], "description": "WhatsApp number → CRM: Alt Contacts" },
          "conference_appearances": { "type": "array", "items": { "type": "string" } },
          "contact_sources": { "type": "array", "items": { "type": "string" }, "description": "Все источники контактной информации" },
          "enrichment_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Для Bucket B: EMAIL_VERIFIED, EMAIL_CATCHALL и т.д. Для Bucket A и SKIP: пусто"
          },
          "enrichment_note": {
            "type": ["string", "null"],
            "description": "Описание процесса обогащения из Enricher (для Bucket B). null для Bucket A и SKIP."
          },
          "flags": { "type": "array", "items": { "type": "string" } },
          "company_contacts": {
            "type": ["object", "null"],
            "description": "Company-level контакты из Pre-Enricher — для колонок Socials и Alt Contacts в CRM. null если Pre-Enricher не обогащал компанию.",
            "properties": {
              "general_email": { "type": ["string", "null"] },
              "press_email": { "type": ["string", "null"] },
              "partnerships_email": { "type": ["string", "null"] },
              "phone": { "type": ["string", "null"] },
              "social_links": {
                "type": ["object", "null"],
                "properties": {
                  "linkedin": { "type": ["string", "null"] },
                  "twitter": { "type": ["string", "null"] },
                  "instagram": { "type": ["string", "null"] },
                  "telegram": { "type": ["string", "null"] }
                }
              }
            }
          },
          "industry_signals": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Сигналы из Pre-Enricher (конференции, спонсорства, найм, запуски) → CRM: Sources & Signals"
          }
        }
      }
    }
  },
