# === AdsGram Pipeline — Environment Configuration ===
# Copy this file to .env and fill in your values.

# --- Anthropic (for OpenClaw / Claude API) ---
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# --- Apollo.io ---
APOLLO_API_KEY=your_apollo_key_here
APOLLO_RATE_LIMIT_RPM=50
APOLLO_DAILY_CREDIT_LIMIT=500

# --- Telegram Bot (for OpenClaw channel) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Google Sheets CRM & Company DB ---
CRM_SHEET_ID=your_crm_sheet_id_here
COMPANYDB_SHEET_ID=your_companydb_sheet_id_here
GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- Gmail (optional — for draft creation) ---
GMAIL_TOKEN_PATH=./gmail_token.json

# --- Telegram Approval Bot (for autonomous mode) ---
# Create bot via @BotFather, get chat_id via: curl https://api.telegram.org/bot<TOKEN>/getUpdates
TG_BOT_TOKEN=your_tg_bot_token_here
TG_OPERATOR_CHAT_ID=your_chat_id_here
# TG_DRY_RUN=1  # Uncomment for testing without real TG

# --- Pipeline Mode ---
# autonomous = VPS headless mode (TG approvals, auto-drafts)
# interactive = default (human in chat)
PIPELINE_MODE=interactive
