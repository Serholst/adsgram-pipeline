# Apollo Outreach CLI — Environment Configuration
# Copy this file to .env and fill in your values.

# Required: Your Apollo.io API key (Settings > API Keys)
APOLLO_API_KEY=your_key_here

# Optional: Path to Excel CRM file (default: crm_all_contacts.xlsx in project dir)
# EXCEL_PATH=crm_all_contacts.xlsx

# Optional: Backup directory (default: backups/)
# BACKUP_DIR=backups

# Optional: Rate limit (requests per minute). Apollo Free Tier = 50.
# RATE_LIMIT_RPM=50

# Optional: Daily credit budget. Set below 600 to leave headroom for web UI.
# DAILY_CREDIT_LIMIT=500
